.venv/
venv/
env/
ENV/
.python-version

# Testing / coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
coverage.xml
*.cover
.hypothesis/

# Type checkers
.mypy_cache/
.pyre/
.pytype/
