
# .env.example
# Copy this file to .env and fill in real values
# Never commit .env

# Required Settings - Must be set for the application to run
DATABASE_URL=postgresql://role:password@localhost:5432/leaderboard
API_KEY=your-secret-key-here
JWT_SECRET=your-jwt-secret-key-here

# Configuration Settings - Necessary with sensible defaults; can be overridden
GUEST_PRUNE_DAYS=30
CACHE_BACKEND=memory #memory or redis

# Optional Settings - Only needed if using certain features
TEST_DATABASE_URL=postgresql://role:password@localhost:5432/leaderboard_test
REDIS_URL=redis://localhost:6379
SENTRY_DSN=https://your-actual-dsn-here